# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# Required: Elsevier Scopus API key
# Obtain from: https://dev.elsevier.com/
ELSEVIER_API_KEY=YOUR_ELSEVIER_API_KEY_HERE

# Optional: delimiter for joining multiple author names in output columns
# Default is semicolon-space.  Change to "|" or "," if needed.
AUTHOR_DELIM="; "
